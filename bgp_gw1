services.frr = {
    enable = true;
    bgpd.enable = true;
    config = ''
      router bgp 1
       bgp bestpath as-path multipath-relax
       neighbor 10.13.10.2 remote-as 2
       neighbor 10.13.30.2 remote-as 3
       address-family ipv4 unicast
        neighbor 10.13.10.2 weight 200
        neighbor 10.13.30.2 weight 100
        network 192.168.13.0/24
       exit-address-family
    '';
  };
