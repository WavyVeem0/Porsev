services.frr = {
    enable = true;
    bgpd.enable = true;
    config = ''
      router bgp 3
       bgp bestpath as-path multipath-relax
       neighbor 10.13.20.1 remote-as 2
       neighbor 10.13.30.1 remote-as 1
       address-family ipv4 unicast
        neighbor 10.13.20.1 weight 100
        neighbor 10.13.30.1 weight 200
        network 192.168.113.0/24
       exit-address-family
    '';
  };
